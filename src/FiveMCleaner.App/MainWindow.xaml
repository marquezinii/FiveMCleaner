<Window x:Class="FiveMCleaner.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="FiveMCleaner"
        Icon="Assets/FiveMCleaner.png"
        Width="1240"
        Height="800"
        MinWidth="1080"
        MinHeight="690"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="7" CornerRadius="0" GlassFrameThickness="0" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <DataTemplate x:Key="ActionTemplate">
            <Border Margin="0,0,0,9" Padding="14" Background="#111317" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="30" Height="30" CornerRadius="8" Background="#20FF7A18" VerticalAlignment="Top">
                        <TextBlock Text="{Binding IconGlyph}" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource OrangeLightBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="8,0,14,0">
                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Description}" Margin="0,4,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="11.5" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                        <Border Padding="8,3" Background="#24272D" CornerRadius="8">
                            <TextBlock Text="{Binding RiskLabel}" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                        </Border>
                        <TextBlock Text="{Binding PrivilegeLabel}" Margin="0,7,0,0" FontSize="10" Foreground="{StaticResource TextSubtleBrush}" HorizontalAlignment="Right" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="LogTemplate">
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Time}" Foreground="{StaticResource TextSubtleBrush}" FontSize="10.5" VerticalAlignment="Center" />
                <Ellipse Grid.Column="1" Width="5" Height="5" Fill="{StaticResource OrangeBrush}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{Binding Message}" Margin="8,0,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="11.5" TextWrapping="Wrap" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="HistoryTemplate">
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="17">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="38" Height="38" CornerRadius="10" Background="#1C37C889">
                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource GreenBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="4,0,18,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" FontSize="13.5" FontWeight="SemiBold" />
                        <TextBlock Margin="0,4,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="11.5">
                            <Run Text="{Binding DateLabel, Mode=OneWay}" /><Run Text="  •  " /><Run Text="{Binding Summary, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                    <Button Grid.Column="2" Content="Desfazer" Style="{StaticResource SecondaryButtonStyle}" Height="36" Padding="16,0" Tag="{Binding}" Click="RollbackHistory_Click" IsEnabled="{Binding CanRollback}" />
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border BorderBrush="#2A2D33" BorderThickness="1" Background="{StaticResource BackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="54" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0E1013" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="14,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="Assets/FiveMCleaner.png" Width="32" Height="32" Stretch="Uniform" />
                        <TextBlock Margin="10,0,0,0" FontSize="15" FontWeight="Bold" VerticalAlignment="Center">
                            <Run Text="FiveM" /><Run Text="Cleaner" Foreground="{StaticResource OrangeBrush}" />
                        </TextBlock>
                        <Border Margin="12,0,0,0" Padding="8,3" Background="#1937C889" CornerRadius="7">
                            <TextBlock Text="LEGACY" FontSize="9" FontWeight="Bold" Foreground="{StaticResource GreenBrush}" />
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource WindowButtonStyle}" Click="Minimize_Click" ToolTip="Minimizar"><TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" /></Button>
                        <Button Style="{StaticResource WindowButtonStyle}" Click="Maximize_Click" ToolTip="Maximizar"><TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10" /></Button>
                        <Button Style="{StaticResource WindowButtonStyle}" Click="Close_Click" ToolTip="Fechar"><TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" /></Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="222" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#0D0F12" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,0,1,0">
                    <Grid Margin="14,22,14,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="NAVEGAÇÃO" Margin="14,0,0,10" FontSize="9.5" FontWeight="Bold" Foreground="{StaticResource TextSubtleBrush}" />
                        <StackPanel Grid.Row="1">
                            <Button x:Name="DashboardNav" Style="{StaticResource NavButtonStyle}" Tag="Selected" Click="DashboardNav_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="29" />
                                    <TextBlock Text="Visão geral" FontSize="13" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="OptimizerNav" Style="{StaticResource NavButtonStyle}" Click="OptimizerNav_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="29" />
                                    <TextBlock Text="Otimizador" FontSize="13" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="HistoryNav" Style="{StaticResource NavButtonStyle}" Click="HistoryNav_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="29" />
                                    <TextBlock Text="Histórico" FontSize="13" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="SettingsNav" Style="{StaticResource NavButtonStyle}" Click="SettingsNav_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="29" />
                                    <TextBlock Text="Configurações" FontSize="13" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <Border Grid.Row="2" Padding="13" Background="#101216" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1" CornerRadius="11">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="25" Height="25" Background="#1C37C889" CornerRadius="7" VerticalAlignment="Top">
                                    <TextBlock Text="&#xEA18;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource GreenBrush}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="7,0,0,0">
                                    <TextBlock Text="Proteção ativa" FontSize="11.5" FontWeight="SemiBold" />
                                    <TextBlock Text="Snapshot e rollback antes de ajustes." Margin="0,4,0,0" Foreground="{StaticResource TextSubtleBrush}" FontSize="10" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="30,24,30,26">
                    <!-- Dashboard -->
                    <ScrollViewer x:Name="DashboardPage" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <Grid Margin="0,0,0,18">
                                <StackPanel>
                                    <TextBlock Text="Visão geral" FontSize="25" FontWeight="Bold" />
                                    <TextBlock Text="Diagnóstico local e otimização transparente para o seu FiveM." Margin="0,6,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="13" />
                                </StackPanel>
                                <Button Content="Reanalisar PC" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Right" Height="38" Padding="15,0" Click="RefreshDiagnostic_Click" IsEnabled="{Binding CanRefresh}" />
                            </Grid>

                            <Border Style="{StaticResource CardStyle}" Background="{StaticResource HeroGradientBrush}" Padding="23" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center" MaxWidth="600" HorizontalAlignment="Left">
                                        <Border Padding="9,4" HorizontalAlignment="Left" Background="#1FFF7A18" CornerRadius="8">
                                            <TextBlock Text="{Binding EditionLabel}" Foreground="{StaticResource OrangeLightBrush}" FontSize="10" FontWeight="Bold" />
                                        </Border>
                                        <TextBlock Text="{Binding RecommendationTitle}" Margin="0,14,0,0" FontSize="20" FontWeight="Bold" />
                                        <TextBlock Text="{Binding RecommendationText}" Margin="0,7,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="12.5" TextWrapping="Wrap" MaxWidth="600" />
                                    </StackPanel>
                                    <Grid Grid.Column="1" Width="122" Height="92" Margin="30,0,4,0">
                                        <Ellipse Stroke="#383B42" StrokeThickness="8" />
                                        <Ellipse Stroke="{StaticResource OrangeBrush}" StrokeThickness="8" StrokeDashArray="4.7,1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" RenderTransformOrigin="0.5,0.5">
                                            <Ellipse.RenderTransform><RotateTransform Angle="-88" /></Ellipse.RenderTransform>
                                        </Ellipse>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ReadinessScore}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
                                            <TextBlock Text="PRONTIDÃO" FontSize="8" Foreground="{StaticResource TextSubtleBrush}" FontWeight="Bold" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="15">
                                    <StackPanel><TextBlock Text="PROCESSADOR" FontSize="8.5" FontWeight="Bold" Foreground="{StaticResource TextSubtleBrush}" /><TextBlock Text="{Binding CpuName}" Margin="0,8,0,0" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" ToolTip="{Binding CpuName}" /></StackPanel>
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="15">
                                    <StackPanel><TextBlock Text="PLACA DE VÍDEO" FontSize="8.5" FontWeight="Bold" Foreground="{StaticResource TextSubtleBrush}" /><TextBlock Text="{Binding GpuName}" Margin="0,8,0,0" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" ToolTip="{Binding GpuName}" /></StackPanel>
                                </Border>
                                <Border Grid.Column="4" Style="{StaticResource CardStyle}" Padding="15">
                                    <StackPanel><TextBlock Text="MEMÓRIA" FontSize="8.5" FontWeight="Bold" Foreground="{StaticResource TextSubtleBrush}" /><TextBlock Text="{Binding RamLabel}" Margin="0,8,0,0" FontSize="12" FontWeight="SemiBold" /></StackPanel>
                                </Border>
                                <Border Grid.Column="6" Style="{StaticResource CardStyle}" Padding="15">
                                    <StackPanel><TextBlock Text="ARMAZENAMENTO" FontSize="8.5" FontWeight="Bold" Foreground="{StaticResource TextSubtleBrush}" /><TextBlock Text="{Binding DiskLabel}" Margin="0,8,0,0" FontSize="12" FontWeight="SemiBold" /></StackPanel>
                                </Border>
                            </Grid>

                            <Grid Margin="0,2,0,9">
                                <TextBlock Text="Escolha o nível" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="Médio é o recomendado para a maioria dos PCs." HorizontalAlignment="Right" Foreground="{StaticResource TextSubtleBrush}" FontSize="11" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <RadioButton Grid.Column="0" GroupName="Profile" Style="{StaticResource ModeRadioStyle}" IsChecked="{Binding IsLightSelected}" Checked="LightProfile_Checked">
                                    <StackPanel>
                                        <Grid><Border Width="31" Height="31" CornerRadius="8" Background="#1C62A8FF" HorizontalAlignment="Left"><TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource BlueBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border><Border Padding="7,3" Background="#1A62A8FF" CornerRadius="7" HorizontalAlignment="Right"><TextBlock Text="VISUAL PRESERVADO" FontSize="8" FontWeight="Bold" Foreground="{StaticResource BlueBrush}" /></Border></Grid>
                                        <TextBlock Text="Leve" Margin="0,13,0,0" FontSize="16" FontWeight="Bold" />
                                        <TextBlock Text="Ajustes suaves, temporários antigos e nenhuma redução gráfica." Margin="0,6,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" TextWrapping="Wrap" />
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton Grid.Column="2" GroupName="Profile" Style="{StaticResource ModeRadioStyle}" IsChecked="{Binding IsBalancedSelected}" Checked="BalancedProfile_Checked">
                                    <StackPanel>
                                        <Grid><Border Width="31" Height="31" CornerRadius="8" Background="#20FF7A18" HorizontalAlignment="Left"><TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource OrangeLightBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border><Border Padding="7,3" Background="#24FF7A18" CornerRadius="7" HorizontalAlignment="Right"><TextBlock Text="RECOMENDADO" FontSize="8" FontWeight="Bold" Foreground="{StaticResource OrangeLightBrush}" /></Border></Grid>
                                        <TextBlock Text="Médio" Margin="0,13,0,0" FontSize="16" FontWeight="Bold" />
                                        <TextBlock Text="Equilíbrio entre qualidade, energia, captura e responsividade." Margin="0,6,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" TextWrapping="Wrap" />
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton Grid.Column="4" GroupName="Profile" Style="{StaticResource ModeRadioStyle}" IsChecked="{Binding IsAggressiveSelected}" Checked="AggressiveProfile_Checked">
                                    <StackPanel>
                                        <Grid><Border Width="31" Height="31" CornerRadius="8" Background="#1CF26B6B" HorizontalAlignment="Left"><TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource RedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border><Border Padding="7,3" Background="#1CF26B6B" CornerRadius="7" HorizontalAlignment="Right"><TextBlock Text="FPS PRIMEIRO" FontSize="8" FontWeight="Bold" Foreground="{StaticResource RedBrush}" /></Border></Grid>
                                        <TextBlock Text="Agressivo" Margin="0,13,0,0" FontSize="16" FontWeight="Bold" />
                                        <TextBlock Text="Reduz efeitos e opções pesadas para computadores limitados." Margin="0,6,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" TextWrapping="Wrap" />
                                    </StackPanel>
                                </RadioButton>
                            </Grid>

                            <Border Style="{StaticResource CardStyle}" Margin="0,14,0,0" Padding="16">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock FontSize="13.5" FontWeight="SemiBold"><Run Text="{Binding SelectedActionCount, Mode=OneWay}" /><Run Text=" ações verificadas  •  " /><Run Text="{Binding ElevationLabel, Mode=OneWay}" Foreground="{StaticResource TextMutedBrush}" /></TextBlock>
                                        <TextBlock Text="{Binding PlanSummary}" Margin="0,5,0,0" Foreground="{StaticResource TextSubtleBrush}" FontSize="10.5" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="Revisar plano" Style="{StaticResource SecondaryButtonStyle}" Height="42" Margin="0,0,9,0" Click="ReviewPlan_Click" />
                                        <Button Content="Otimizar agora" Style="{StaticResource PrimaryButtonStyle}" Height="42" Click="StartOptimization_Click" IsEnabled="{Binding CanStart}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Optimizer -->
                    <Grid x:Name="OptimizerPage" Visibility="Collapsed">
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <Grid Margin="0,0,0,18">
                            <StackPanel><TextBlock Text="Otimizador" FontSize="25" FontWeight="Bold" /><TextBlock Text="Plano determinístico: o helper aceita somente ações internas conhecidas." Margin="0,6,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="13" /></StackPanel>
                            <Border HorizontalAlignment="Right" Padding="10,5" Background="#1837C889" CornerRadius="8" VerticalAlignment="Center"><TextBlock Text="SEM SCRIPTS REMOTOS" Foreground="{StaticResource GreenBrush}" FontSize="9" FontWeight="Bold" /></Border>
                        </Grid>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="1.08*" /><ColumnDefinition Width="15" /><ColumnDefinition Width="0.92*" /></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="18">
                                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                    <Grid Margin="0,0,0,13"><StackPanel><TextBlock Text="Plano atual" FontSize="15" FontWeight="SemiBold" /><TextBlock Text="{Binding PlanHeader}" Margin="0,4,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="11" /></StackPanel><Border HorizontalAlignment="Right" Padding="9,4" Background="#24272D" CornerRadius="7"><TextBlock Text="{Binding SelectedProfileLabel}" FontSize="9" FontWeight="Bold" Foreground="{StaticResource OrangeLightBrush}" /></Border></Grid>
                                    <Border Grid.Row="1" Margin="0,0,0,11" Padding="11,8" Background="#1FFF7A18" BorderBrush="#45FF7A18" BorderThickness="1" CornerRadius="8"><TextBlock Text="{Binding PlanNoticesText}" Foreground="{StaticResource OrangeLightBrush}" FontSize="10" TextWrapping="Wrap" /></Border>
                                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"><ItemsControl ItemsSource="{Binding PlannedActions}" ItemTemplate="{StaticResource ActionTemplate}" /></ScrollViewer>
                                    <Grid Grid.Row="3" Margin="0,13,0,0"><Button Content="Executar plano" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Click="StartOptimization_Click" IsEnabled="{Binding CanStart}" /><TextBlock Text="{Binding SafetySummary}" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource TextSubtleBrush}" FontSize="10.5" /></Grid>
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="20">
                                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                    <Grid><StackPanel><TextBlock Text="Progresso" FontSize="15" FontWeight="SemiBold" /><TextBlock Text="{Binding ProgressStateLabel}" Margin="0,4,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="11" /></StackPanel><TextBlock Text="{Binding ProgressPercent, Mode=OneWay, StringFormat={}{0:0}%}" HorizontalAlignment="Right" FontSize="22" FontWeight="Bold" Foreground="{StaticResource OrangeLightBrush}" /></Grid>
                                    <StackPanel Grid.Row="1" Margin="0,18,0,15"><ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}" Maximum="100" /><TextBlock Text="{Binding ProgressHeadline}" Margin="0,11,0,0" FontSize="13" FontWeight="SemiBold" /><TextBlock Text="{Binding ProgressDetail}" Margin="0,4,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" TextWrapping="Wrap" /></StackPanel>
                                    <Border Grid.Row="2" Background="#0C0E11" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1" CornerRadius="10" Padding="13"><ScrollViewer VerticalScrollBarVisibility="Auto"><ItemsControl ItemsSource="{Binding ActivityLog}" ItemTemplate="{StaticResource LogTemplate}" /></ScrollViewer></Border>
                                    <Button Grid.Row="3" Content="Cancelar após esta etapa" Style="{StaticResource SecondaryButtonStyle}" Margin="0,13,0,0" HorizontalAlignment="Stretch" Click="CancelOptimization_Click" IsEnabled="{Binding CanCancel}" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- History -->
                    <Grid x:Name="HistoryPage" Visibility="Collapsed">
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <Grid Margin="0,0,0,18"><StackPanel><TextBlock Text="Histórico" FontSize="25" FontWeight="Bold" /><TextBlock Text="Cada execução guarda ações, resultados e os estados necessários para rollback." Margin="0,6,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="13" /></StackPanel><Button Content="Abrir pasta de logs" HorizontalAlignment="Right" Style="{StaticResource SecondaryButtonStyle}" Height="38" Click="OpenLogs_Click" /></Grid>
                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="18">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Grid Margin="0,0,0,14"><TextBlock Text="Execuções locais" FontSize="15" FontWeight="SemiBold" /><TextBlock Text="Sem telemetria" HorizontalAlignment="Right" Foreground="{StaticResource GreenBrush}" FontSize="10" FontWeight="Bold" /></Grid>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"><ItemsControl ItemsSource="{Binding HistoryItems}" ItemTemplate="{StaticResource HistoryTemplate}" /></ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Settings -->
                    <ScrollViewer x:Name="SettingsPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Configurações" FontSize="25" FontWeight="Bold" />
                            <TextBlock Text="Controle exatamente o que entra em cada execução." Margin="0,6,0,18" Foreground="{StaticResource TextMutedBrush}" FontSize="13" />

                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,13">
                                <StackPanel>
                                    <TextBlock Text="Limpeza e diagnóstico" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="Nunca apagamos Downloads, Lixeira, game-storage, NUI, login ou shader cache." Margin="0,5,0,16" Foreground="{StaticResource TextSubtleBrush}" FontSize="10.5" />
                                    <CheckBox Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding CleanTemporaryFiles}"><StackPanel><TextBlock Text="Temporários antigos do usuário" FontSize="12.5" FontWeight="SemiBold" /><TextBlock Text="Somente arquivos fora da janela de retenção e que não estão em uso." Margin="0,3,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" /></StackPanel></CheckBox>
                                    <Separator Margin="0,13" Background="{StaticResource BorderSoftBrush}" />
                                    <CheckBox Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding RemoveOldDiagnostics}"><StackPanel><TextBlock Text="Logs e dumps antigos do FiveM" FontSize="12.5" FontWeight="SemiBold" /><TextBlock Text="Mantém diagnósticos recentes para suporte e remove somente os antigos." Margin="0,3,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" /></StackPanel></CheckBox>
                                    <Separator Margin="0,13" Background="{StaticResource BorderSoftBrush}" />
                                    <CheckBox Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding SmartCacheRepair}"><StackPanel><TextBlock Text="Reparo inteligente do cache de servidores" FontSize="12.5" FontWeight="SemiBold" /><TextBlock Text="Só age quando o cache Legacy excede o limite; o primeiro carregamento fica mais lento." Margin="0,3,0,0" Foreground="{StaticResource YellowBrush}" FontSize="10.5" /></StackPanel></CheckBox>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,13">
                                <StackPanel>
                                    <TextBlock Text="Jogos e Windows" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="Mudanças suportadas, registradas e reversíveis." Margin="0,5,0,16" Foreground="{StaticResource TextSubtleBrush}" FontSize="10.5" />
                                    <CheckBox Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding EnableGameMode}"><StackPanel><TextBlock Text="Modo de Jogo do Windows" FontSize="12.5" FontWeight="SemiBold" /><TextBlock Text="Ativa priorização para jogos sem mexer em serviços essenciais." Margin="0,3,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" /></StackPanel></CheckBox>
                                    <Separator Margin="0,13" Background="{StaticResource BorderSoftBrush}" />
                                    <CheckBox Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding DisableBackgroundCapture}"><StackPanel><TextBlock Text="Desativar gravação em segundo plano" FontSize="12.5" FontWeight="SemiBold" /><TextBlock Text="Mantém o Game Bar, mas evita captura contínua durante a sessão." Margin="0,3,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" /></StackPanel></CheckBox>
                                    <Separator Margin="0,13" Background="{StaticResource BorderSoftBrush}" />
                                    <CheckBox Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding UsePerformancePowerPlan}"><StackPanel><TextBlock Text="Plano de energia de alto desempenho" FontSize="12.5" FontWeight="SemiBold" /><TextBlock Text="Somente na tomada; mantém até você usar Desfazer no histórico." Margin="0,3,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" /></StackPanel></CheckBox>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Limites de segurança" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="O FiveMCleaner nunca desativa Defender, Firewall, UAC, Windows Update, pagefile ou serviços críticos; não usa BCDEdit/HPET, injeção, hooks ou prioridade Realtime." Margin="0,9,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="11.5" TextWrapping="Wrap" />
                                    <TextBlock Text="FiveM Enhanced: bloqueado nesta versão até o layout oficial ser testado." Margin="0,8,0,0" Foreground="{StaticResource OrangeLightBrush}" FontSize="11" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
