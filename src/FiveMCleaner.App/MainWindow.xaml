<Window x:Class="FiveMCleaner.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="FiveMCleaner"
        Icon="Assets/FiveMCleaner.png"
        Width="1160"
        Height="680"
        MinWidth="960"
        MinHeight="580"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{DynamicResource BackgroundBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="7" CornerRadius="0" GlassFrameThickness="0" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <DataTemplate x:Key="ActionTemplate">
            <Border Margin="0,0,0,9" Padding="14" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="30" Height="30" CornerRadius="8" Background="#20FF7A18" VerticalAlignment="Top">
                        <TextBlock Text="{Binding IconGlyph}" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource OrangeLightBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="8,0,14,0">
                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Description}" Margin="0,4,0,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="11.5" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                        <Border Padding="8,3" Background="{DynamicResource ChipBrush}" CornerRadius="8">
                            <TextBlock Text="{Binding RiskLabel}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
                        </Border>
                        <TextBlock Text="{Binding PrivilegeLabel}" Margin="0,7,0,0" FontSize="10" Foreground="{DynamicResource TextSubtleBrush}" HorizontalAlignment="Right" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="LogTemplate">
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Time}" Foreground="{DynamicResource TextSubtleBrush}" FontSize="10.5" VerticalAlignment="Center" />
                <Ellipse Grid.Column="1" Width="5" Height="5" Fill="{DynamicResource OrangeBrush}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{Binding Message}" Margin="8,0,0,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="11.5" TextWrapping="Wrap" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="StepLedgerTemplate">
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Name}" FontSize="10.5" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                <Border Grid.Column="1" Padding="7,2" Background="{DynamicResource ChipBrush}" CornerRadius="6" Margin="8,0,0,0">
                    <TextBlock Text="{Binding OutcomeLabel}" FontSize="9" FontWeight="SemiBold" Foreground="{Binding OutcomeBrushKey, Converter={StaticResource BrushKeyConverter}}" />
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ReportLineTemplate">
            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding ActionName}" FontSize="10.5" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Reason}" FontSize="9" Foreground="{DynamicResource TextSubtleBrush}" TextWrapping="Wrap" Visibility="{Binding Reason, Converter={StaticResource StringToVisibilityConverter}}" />
                </StackPanel>
                <Border Grid.Column="1" Padding="7,2" Background="{DynamicResource ChipBrush}" CornerRadius="6" Margin="8,0,0,0" VerticalAlignment="Top">
                    <TextBlock Text="{Binding OutcomeLabel}" FontSize="9" FontWeight="SemiBold" Foreground="{Binding OutcomeBrushKey, Converter={StaticResource BrushKeyConverter}}" />
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="HistoryTemplate">
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="17">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="38" Height="38" CornerRadius="10" Background="#1C37C889">
                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource GreenBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="4,0,18,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" FontSize="13.5" FontWeight="SemiBold" />
                        <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="11.5">
                            <Run Text="{Binding DateLabel, Mode=OneWay}" /><Run Text="  •  " /><Run Text="{Binding Summary, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                    <Button Grid.Column="2" Content="{Binding [History.Undo], Source={StaticResource LocalizedStrings}}" Style="{StaticResource SecondaryButtonStyle}" Height="36" Padding="16,0" Tag="{Binding}" Click="RollbackHistory_Click" IsEnabled="{Binding CanRollback}" />
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource StrongBorderBrush}" BorderThickness="1" Background="{DynamicResource BackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="54" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource ChromeBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="14,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="Assets/FiveMCleaner.png" Width="32" Height="32" Stretch="Uniform" />
                        <TextBlock Margin="10,0,0,0" FontSize="15" FontWeight="Bold" VerticalAlignment="Center">
                            <Run Text="FiveM" /><Run Text="Cleaner" Foreground="{DynamicResource OrangeBrush}" />
                        </TextBlock>
                        <Border Margin="12,0,0,0" MinHeight="26" Padding="9,0" Background="{DynamicResource ChipBrush}" CornerRadius="8" VerticalAlignment="Center">
                            <TextBlock Text="{Binding EditionBadgeLabel}" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource OrangeLightBrush}" VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource WindowButtonStyle}" Click="Minimize_Click" ToolTip="{Binding [Window.Minimize], Source={StaticResource LocalizedStrings}}"><TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" /></Button>
                        <Button x:Name="MaximizeButton" Style="{StaticResource WindowButtonStyle}" Click="Maximize_Click" ToolTip="{Binding [Window.Maximize], Source={StaticResource LocalizedStrings}}"><TextBlock x:Name="MaximizeGlyph" Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10" /></Button>
                        <Button Style="{StaticResource CloseWindowButtonStyle}" Click="Close_Click" ToolTip="{Binding [Window.Close], Source={StaticResource LocalizedStrings}}"><TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" /></Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="0,0,1,0">
                    <Grid Margin="14,22,14,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding [Navigation.Section], Source={StaticResource LocalizedStrings}}" Margin="14,0,0,10" FontSize="9.5" FontWeight="Bold" Foreground="{DynamicResource TextSubtleBrush}" />
                        <StackPanel Grid.Row="1">
                            <Button x:Name="DashboardNav" Style="{StaticResource NavButtonStyle}" Tag="Selected" Click="DashboardNav_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="29" />
                                    <TextBlock Text="{Binding [Navigation.Overview], Source={StaticResource LocalizedStrings}}" FontSize="13" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="OptimizerNav" Style="{StaticResource NavButtonStyle}" Click="OptimizerNav_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="29" />
                                    <TextBlock Text="{Binding [Navigation.Optimizer], Source={StaticResource LocalizedStrings}}" FontSize="13" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="HistoryNav" Style="{StaticResource NavButtonStyle}" Click="HistoryNav_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="29" />
                                    <TextBlock Text="{Binding [Navigation.History], Source={StaticResource LocalizedStrings}}" FontSize="13" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="SettingsNav" Style="{StaticResource NavButtonStyle}" Click="SettingsNav_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="29" />
                                    <TextBlock Text="{Binding [Navigation.Settings], Source={StaticResource LocalizedStrings}}" FontSize="13" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Row="2">
                            <Border Padding="13" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="11" ToolTip="{Binding [Safety.SnapshotRollback], Source={StaticResource LocalizedStrings}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="25" Height="25" Background="#1C37C889" CornerRadius="7" VerticalAlignment="Top">
                                        <TextBlock Text="&#xEA18;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource GreenBrush}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="7,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding [Safety.Active], Source={StaticResource LocalizedStrings}}" FontSize="11.5" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <TextBlock Margin="0,9,0,0" HorizontalAlignment="Center" Foreground="{DynamicResource TextSubtleBrush}" FontSize="9.5">
                                <Run Text="v " />
                                <Run Text="{Binding AppVersion, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="26,22,26,24">
                    <!-- Dashboard -->
                    <ScrollViewer x:Name="DashboardPage" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,18,0">
                                    <TextBlock Text="{Binding [Dashboard.Title], Source={StaticResource LocalizedStrings}}" FontSize="25" FontWeight="Bold" />
                                </StackPanel>
                                <Button Grid.Column="1" Content="{Binding [Dashboard.Refresh], Source={StaticResource LocalizedStrings}}" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Right" Height="38" Padding="15,0" Click="RefreshDiagnostic_Click" IsEnabled="{Binding CanRefresh}" />
                            </Grid>

                            <Border Margin="0,0,0,16"
                                    Padding="16,14"
                                    Background="#16FF7A18"
                                    BorderBrush="#56FF7A18"
                                    BorderThickness="1"
                                    CornerRadius="11"
                                    Visibility="{Binding IsUpdateBannerVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="27" Height="27" CornerRadius="8" Background="#25FF7A18" VerticalAlignment="Top">
                                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{DynamicResource OrangeLightBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="7,0,18,0">
                                        <TextBlock Text="{Binding UpdateBannerTitle}" FontSize="12.5" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding UpdateBannerDetail}" Margin="0,4,0,0" FontSize="10.5" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <Button Content="{Binding UpdateActionLabel}"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Height="36"
                                                MinWidth="132"
                                                Padding="15,0"
                                                IsEnabled="{Binding CanDownloadUpdate}"
                                                Click="DownloadUpdate_Click" />
                                        <Button Content="{Binding UpdateReleaseNotesLabel}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="{DynamicResource OrangeLightBrush}"
                                                FontSize="10.5"
                                                Padding="4,7,4,0"
                                                HorizontalAlignment="Center"
                                                IsEnabled="{Binding CanOpenReleaseNotes}"
                                                Click="OpenReleaseNotes_Click" />
                                    </StackPanel>
                                    <ProgressBar Grid.Row="1"
                                                 Grid.Column="1"
                                                 Grid.ColumnSpan="2"
                                                 Height="3"
                                                 Margin="7,10,0,0"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding UpdateDownloadPercent, Mode=OneWay}"
                                                 Visibility="{Binding IsUpdateDownloading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Background="{DynamicResource HeroGradientBrush}" Padding="23" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center" MaxWidth="600" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal">
                                            <Border MinHeight="32" Padding="10,0" CornerRadius="9" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#1CF26B6B" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFiveMLegacyDetected}" Value="True"><Setter Property="Background" Value="#1C37C889" /></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center">
                                                        <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Text" Value="&#xE711;" /><Setter Property="Foreground" Value="{DynamicResource RedBrush}" /><Style.Triggers><DataTrigger Binding="{Binding IsFiveMLegacyDetected}" Value="True"><Setter Property="Text" Value="&#xE73E;" /><Setter Property="Foreground" Value="{DynamicResource GreenBrush}" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding EditionLabel}" Margin="6,0,0,0" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center">
                                                        <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource RedBrush}" /><Style.Triggers><DataTrigger Binding="{Binding IsFiveMLegacyDetected}" Value="True"><Setter Property="Foreground" Value="{DynamicResource GreenBrush}" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                            <Border Margin="7,0,0,0" MinHeight="32" Padding="10,0" CornerRadius="9" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#1CF26B6B" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsGtaVLegacyDetected}" Value="True"><Setter Property="Background" Value="#1C37C889" /></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center">
                                                        <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Text" Value="&#xE711;" /><Setter Property="Foreground" Value="{DynamicResource RedBrush}" /><Style.Triggers><DataTrigger Binding="{Binding IsGtaVLegacyDetected}" Value="True"><Setter Property="Text" Value="&#xE73E;" /><Setter Property="Foreground" Value="{DynamicResource GreenBrush}" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding GtaStatusLabel}" Margin="6,0,0,0" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center">
                                                        <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource RedBrush}" /><Style.Triggers><DataTrigger Binding="{Binding IsGtaVLegacyDetected}" Value="True"><Setter Property="Foreground" Value="{DynamicResource GreenBrush}" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding RecommendationTitle}" Margin="0,14,0,0" FontSize="20" FontWeight="Bold" />
                                         <TextBlock Text="{Binding RecommendationText}" Margin="0,7,0,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="12.5" TextWrapping="Wrap" MaxWidth="600" />
                                         <TextBlock Text="{Binding ReadinessScoreExplanation}" Margin="0,11,0,0" Foreground="{DynamicResource TextSubtleBrush}" FontSize="10" TextWrapping="Wrap" MaxWidth="600" />
                                     </StackPanel>
                                     <Grid Grid.Column="1" Width="112" Height="112" Margin="30,0,4,0" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="{Binding ReadinessScoreExplanation}">
                                         <Ellipse Width="108" Height="108" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" Fill="{DynamicResource SurfaceBrush}" Stroke="{DynamicResource OrangeBrush}" StrokeThickness="7" />
                                         <Ellipse Width="90" Height="90" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" Stroke="{DynamicResource RingBrush}" StrokeThickness="1" />
                                         <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                             <TextBlock Text="{Binding ReadinessScore}" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" />
                                             <TextBlock Text="{Binding [Dashboard.Readiness], Source={StaticResource LocalizedStrings}}" FontSize="8" Foreground="{DynamicResource TextSubtleBrush}" FontWeight="Bold" HorizontalAlignment="Center" />
                                         </StackPanel>
                                     </Grid>
                                </Grid>
                            </Border>

                            <primitives:UniformGrid Columns="2" Margin="0,0,0,16">
                                <Border Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,8,8"><StackPanel><TextBlock Text="{Binding [Dashboard.Processor], Source={StaticResource LocalizedStrings}}" FontSize="8.5" FontWeight="Bold" Foreground="{DynamicResource TextSubtleBrush}" /><TextBlock Text="{Binding CpuName}" Margin="0,8,0,0" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" ToolTip="{Binding CpuName}" /></StackPanel></Border>
                                <Border Style="{StaticResource CardStyle}" Padding="15" Margin="8,0,0,8"><StackPanel><TextBlock Text="{Binding [Dashboard.GraphicsCard], Source={StaticResource LocalizedStrings}}" FontSize="8.5" FontWeight="Bold" Foreground="{DynamicResource TextSubtleBrush}" /><TextBlock Text="{Binding GpuDetail}" Margin="0,8,0,0" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" ToolTip="{Binding GpuDetail}" /></StackPanel></Border>
                                <Border Style="{StaticResource CardStyle}" Padding="15" Margin="0,8,8,0"><StackPanel><TextBlock Text="{Binding [Dashboard.Memory], Source={StaticResource LocalizedStrings}}" FontSize="8.5" FontWeight="Bold" Foreground="{DynamicResource TextSubtleBrush}" /><TextBlock Text="{Binding RamLabel}" Margin="0,8,0,0" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" /></StackPanel></Border>
                                <Border Style="{StaticResource CardStyle}" Padding="15" Margin="8,8,0,0"><StackPanel><TextBlock Text="{Binding [Dashboard.Storage], Source={StaticResource LocalizedStrings}}" FontSize="8.5" FontWeight="Bold" Foreground="{DynamicResource TextSubtleBrush}" /><TextBlock Text="{Binding DiskLabel}" Margin="0,8,0,0" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" /></StackPanel></Border>
                                <Border Style="{StaticResource CardStyle}" Padding="15" Margin="0,8,8,0"><StackPanel><TextBlock Text="{Binding [Dashboard.Windows], Source={StaticResource LocalizedStrings}}" FontSize="8.5" FontWeight="Bold" Foreground="{DynamicResource TextSubtleBrush}" /><TextBlock Text="{Binding WindowsLabel}" Margin="0,8,0,0" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" ToolTip="{Binding WindowsLabel}" /></StackPanel></Border>
                                <Border Style="{StaticResource CardStyle}" Padding="15" Margin="8,8,0,0"><StackPanel><TextBlock Text="{Binding [Dashboard.Architecture], Source={StaticResource LocalizedStrings}}" FontSize="8.5" FontWeight="Bold" Foreground="{DynamicResource TextSubtleBrush}" /><TextBlock Text="{Binding ArchitectureLabel}" Margin="0,8,0,0" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" /></StackPanel></Border>
                            </primitives:UniformGrid>

                            <Grid Margin="0,2,0,9">
                                <TextBlock Text="{Binding [Profiles.Choose], Source={StaticResource LocalizedStrings}}" Style="{StaticResource SectionTitleStyle}" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <RadioButton Grid.Column="0" GroupName="Profile" Style="{StaticResource ModeRadioStyle}" IsChecked="{Binding IsLightSelected}" Checked="LightProfile_Checked">
                                    <StackPanel>
                                        <Border Width="34" Height="34" CornerRadius="9" Background="{DynamicResource ChipBrush}" HorizontalAlignment="Left">
                                            <Canvas Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="M 4,21 A 10,10 0 0 1 24,21" Stroke="{DynamicResource TextSubtleBrush}" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                <Line X1="14" Y1="21" X2="7" Y2="17" Stroke="{DynamicResource GreenBrush}" StrokeThickness="2.2" StrokeStartLineCap="Round" />
                                                <Ellipse Canvas.Left="12" Canvas.Top="19" Width="4" Height="4" Fill="{DynamicResource GreenBrush}" />
                                            </Canvas>
                                        </Border>
                                        <TextBlock Text="{Binding [Profiles.Light.Name], Source={StaticResource LocalizedStrings}}" Margin="0,13,0,0" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding [Profiles.Light.Description], Source={StaticResource LocalizedStrings}}" Margin="0,6,0,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="10.5" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding LightImpactLabel}" Margin="0,9,0,0" Foreground="{DynamicResource BlueBrush}" FontSize="9.5" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton Grid.Column="2" GroupName="Profile" Style="{StaticResource ModeRadioStyle}" IsChecked="{Binding IsBalancedSelected}" Checked="BalancedProfile_Checked">
                                    <StackPanel>
                                        <Grid><Border Width="34" Height="34" CornerRadius="9" Background="{DynamicResource ChipBrush}" HorizontalAlignment="Left"><Canvas Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center"><Path Data="M 4,21 A 10,10 0 0 1 24,21" Stroke="{DynamicResource TextSubtleBrush}" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" /><Line X1="14" Y1="21" X2="14" Y2="10" Stroke="{DynamicResource OrangeLightBrush}" StrokeThickness="2.2" StrokeStartLineCap="Round" /><Ellipse Canvas.Left="12" Canvas.Top="19" Width="4" Height="4" Fill="{DynamicResource OrangeLightBrush}" /></Canvas></Border><Border MinHeight="25" Padding="9,0" Background="#24FF7A18" CornerRadius="7" HorizontalAlignment="Right" VerticalAlignment="Center"><TextBlock Text="{Binding [Profiles.Balanced.Badge], Source={StaticResource LocalizedStrings}}" FontSize="8.5" FontWeight="SemiBold" Foreground="{DynamicResource OrangeLightBrush}" VerticalAlignment="Center" /></Border></Grid>
                                        <TextBlock Text="{Binding [Profiles.Balanced.Name], Source={StaticResource LocalizedStrings}}" Margin="0,13,0,0" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding [Profiles.Balanced.Description], Source={StaticResource LocalizedStrings}}" Margin="0,6,0,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="10.5" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding BalancedImpactLabel}" Margin="0,9,0,0" Foreground="{DynamicResource OrangeLightBrush}" FontSize="9.5" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton Grid.Column="4" GroupName="Profile" Style="{StaticResource ModeRadioStyle}" IsChecked="{Binding IsAggressiveSelected}" Checked="AggressiveProfile_Checked">
                                    <StackPanel>
                                        <Border Width="34" Height="34" CornerRadius="9" Background="{DynamicResource ChipBrush}" HorizontalAlignment="Left">
                                            <Canvas Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="M 4,21 A 10,10 0 0 1 24,21" Stroke="{DynamicResource TextSubtleBrush}" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                <Line X1="14" Y1="21" X2="21" Y2="17" Stroke="{DynamicResource RedBrush}" StrokeThickness="2.2" StrokeStartLineCap="Round" />
                                                <Ellipse Canvas.Left="12" Canvas.Top="19" Width="4" Height="4" Fill="{DynamicResource RedBrush}" />
                                            </Canvas>
                                        </Border>
                                        <TextBlock Text="{Binding [Profiles.Aggressive.Name], Source={StaticResource LocalizedStrings}}" Margin="0,13,0,0" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding [Profiles.Aggressive.Description], Source={StaticResource LocalizedStrings}}" Margin="0,6,0,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="10.5" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding AggressiveImpactLabel}" Margin="0,9,0,0" Foreground="{DynamicResource RedBrush}" FontSize="9.5" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    </StackPanel>
                                </RadioButton>
                            </Grid>

                            <Border Style="{StaticResource CardStyle}" Margin="0,14,0,0" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="{Binding [Profiles.Presentation.Benefits.Label], Source={StaticResource LocalizedStrings}}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextSubtleBrush}" />
                                    <TextBlock Text="{Binding ProfilePresentationBenefits}" Margin="0,4,0,0" FontSize="11.5" TextWrapping="Wrap" />
                                    <primitives:UniformGrid Columns="2" Margin="0,12,0,0">
                                        <StackPanel Margin="0,0,10,10">
                                            <TextBlock Text="{Binding [Profiles.Presentation.Impact.Label], Source={StaticResource LocalizedStrings}}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextSubtleBrush}" />
                                            <TextBlock Text="{Binding ProfilePresentationImpact}" Margin="0,4,0,0" FontSize="11" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="{Binding [Profiles.Presentation.Reversibility.Label], Source={StaticResource LocalizedStrings}}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextSubtleBrush}" />
                                            <TextBlock Text="{Binding ProfilePresentationReversibility}" Margin="0,4,0,0" FontSize="11" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,10,0">
                                            <TextBlock Text="{Binding [Profiles.Presentation.Risks.Label], Source={StaticResource LocalizedStrings}}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextSubtleBrush}" />
                                            <TextBlock Text="{Binding ProfilePresentationRisks}" Margin="0,4,0,0" FontSize="11" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="{Binding [Profiles.Presentation.Categories.Label], Source={StaticResource LocalizedStrings}}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextSubtleBrush}" />
                                            <TextBlock Text="{Binding ProfilePresentationCategories}" Margin="0,4,0,0" FontSize="11" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </primitives:UniformGrid>
                                    <TextBlock Text="{Binding ProfilePresentationVariability}" Margin="0,10,0,0" Foreground="{DynamicResource TextSubtleBrush}" FontSize="10" FontStyle="Italic" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Margin="0,14,0,0" Padding="16">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock FontSize="13.5" FontWeight="SemiBold" TextWrapping="Wrap"><Run Text="{Binding SelectedActionCount, Mode=OneWay}" /><Run Text=" " /><Run Text="{Binding [Plan.VerifiedActions.Label], Source={StaticResource LocalizedStrings}, Mode=OneWay}" /><Run Text="  •  " /><Run Text="{Binding ElevationLabel, Mode=OneWay}" Foreground="{DynamicResource TextMutedBrush}" /></TextBlock>
                                        <TextBlock Text="{Binding PlanSummary}" Margin="0,5,0,0" Foreground="{DynamicResource TextSubtleBrush}" FontSize="10.5" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="{Binding [Plan.Review], Source={StaticResource LocalizedStrings}}" Style="{StaticResource SecondaryButtonStyle}" Height="42" Margin="0,0,9,0" Click="ReviewPlan_Click" />
                                        <Button Content="{Binding [Plan.OptimizeNow], Source={StaticResource LocalizedStrings}}" Style="{StaticResource PrimaryButtonStyle}" Height="42" Click="StartOptimization_Click" IsEnabled="{Binding CanStart}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Optimizer -->
                    <Grid x:Name="OptimizerPage" Visibility="Collapsed">
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,18,0"><TextBlock Text="{Binding [Optimizer.Title], Source={StaticResource LocalizedStrings}}" FontSize="25" FontWeight="Bold" /><TextBlock Text="{Binding [Optimizer.Subtitle], Source={StaticResource LocalizedStrings}}" Margin="0,6,0,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="13" TextWrapping="Wrap" /></StackPanel>
                            <Border Grid.Column="1" HorizontalAlignment="Right" Padding="10,5" Background="#1837C889" CornerRadius="8" VerticalAlignment="Center"><TextBlock Text="{Binding [Optimizer.NoRemoteScripts], Source={StaticResource LocalizedStrings}}" Foreground="{DynamicResource GreenBrush}" FontSize="9" FontWeight="Bold" /></Border>
                        </Grid>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="1.08*" /><ColumnDefinition Width="15" /><ColumnDefinition Width="0.92*" /></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="18">
                                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                    <Grid Margin="0,0,0,13"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel Margin="0,0,12,0"><TextBlock Text="{Binding [Optimizer.CurrentPlan], Source={StaticResource LocalizedStrings}}" FontSize="15" FontWeight="SemiBold" /><TextBlock Text="{Binding PlanHeader}" Margin="0,4,0,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" TextWrapping="Wrap" /></StackPanel><Border Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" MinHeight="28" Padding="9,0" Background="{DynamicResource ChipBrush}" CornerRadius="7"><TextBlock Text="{Binding SelectedProfileLabel}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource OrangeLightBrush}" VerticalAlignment="Center" /></Border></Grid>
                                    <Border Grid.Row="1" Margin="0,0,0,11" Padding="11,8" Background="#1FFF7A18" BorderBrush="#45FF7A18" BorderThickness="1" CornerRadius="8"><TextBlock Text="{Binding PlanNoticesText}" Foreground="{DynamicResource OrangeLightBrush}" FontSize="10" TextWrapping="Wrap" /></Border>
                                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"><ItemsControl ItemsSource="{Binding PlannedActions}" ItemTemplate="{StaticResource ActionTemplate}" /></ScrollViewer>
                                    <Grid Grid.Row="3" Margin="0,13,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Button Content="{Binding [Optimizer.RunPlan], Source={StaticResource LocalizedStrings}}" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Click="StartOptimization_Click" IsEnabled="{Binding CanStart}" /><TextBlock Grid.Column="1" Text="{Binding SafetySummary}" Margin="12,0,0,0" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{DynamicResource TextSubtleBrush}" FontSize="10.5" TextWrapping="Wrap" TextAlignment="Right" /></Grid>
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="20">
                                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel Margin="0,0,12,0"><TextBlock Text="{Binding [Progress.Title], Source={StaticResource LocalizedStrings}}" FontSize="15" FontWeight="SemiBold" /><TextBlock Text="{Binding ProgressStateLabel}" Margin="0,4,0,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" TextWrapping="Wrap" /></StackPanel><TextBlock Grid.Column="1" Text="{Binding ProgressPercent, Mode=OneWay, StringFormat={}{0:0}%}" HorizontalAlignment="Right" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource OrangeLightBrush}" /></Grid>
                                    <StackPanel Grid.Row="1" Margin="0,18,0,15">
                                        <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}" Maximum="100" />
                                        <Grid Margin="0,7,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding ElapsedTimeLabel}" Foreground="{DynamicResource TextSubtleBrush}" FontSize="10" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" Text="{Binding RemainingTimeLabel}" Foreground="{DynamicResource TextSubtleBrush}" FontSize="10" HorizontalAlignment="Right" TextAlignment="Right" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                        <TextBlock Text="{Binding StepCounterLabel}" Margin="0,7,0,0" Foreground="{DynamicResource OrangeLightBrush}" FontSize="10" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding ProgressHeadline}" Margin="0,11,0,0" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                                        <TextBlock Text="{Binding ProgressDetail}" Margin="0,4,0,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="10.5" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                                    </StackPanel>
                                    <Border Grid.Row="2" Margin="0,0,0,11" MaxHeight="120" Visibility="{Binding HasStepLedgerItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding [Optimizer.StepLedger.Title], Source={StaticResource LocalizedStrings}}" Margin="0,0,0,6" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextSubtleBrush}" />
                                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="96"><ItemsControl ItemsSource="{Binding StepLedger}" ItemTemplate="{StaticResource StepLedgerTemplate}" /></ScrollViewer>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="3" Background="{DynamicResource InsetBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="10" Padding="13"><ScrollViewer VerticalScrollBarVisibility="Auto"><ItemsControl ItemsSource="{Binding ActivityLog}" ItemTemplate="{StaticResource LogTemplate}" /></ScrollViewer></Border>
                                    <Border Grid.Row="4" Margin="0,13,0,0" Padding="13" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="10" Visibility="{Binding IsReportAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding [Report.Title], Source={StaticResource LocalizedStrings}}" FontSize="12.5" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding ReportSummaryLabel}" Margin="0,6,0,0" FontSize="10.5" TextWrapping="Wrap" Foreground="{DynamicResource TextMutedBrush}" />
                                            <TextBlock Text="{Binding ReportRestartLabel}" Margin="0,4,0,0" FontSize="10" TextWrapping="Wrap" Foreground="{DynamicResource TextSubtleBrush}" />
                                            <ScrollViewer MaxHeight="140" Margin="0,10,0,0" VerticalScrollBarVisibility="Auto"><ItemsControl ItemsSource="{Binding ReportLines}" ItemTemplate="{StaticResource ReportLineTemplate}" /></ScrollViewer>
                                            <Button Content="{Binding [Report.CopyButton], Source={StaticResource LocalizedStrings}}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,10,0,0" HorizontalAlignment="Stretch" Click="CopyTechnicalReport_Click" />
                                        </StackPanel>
                                    </Border>
                                    <Button Grid.Row="5" Content="{Binding [Progress.CancelAfterStep], Source={StaticResource LocalizedStrings}}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,13,0,0" HorizontalAlignment="Stretch" Click="CancelOptimization_Click" IsEnabled="{Binding CanCancel}" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- History -->
                    <Grid x:Name="HistoryPage" Visibility="Collapsed">
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <Grid Margin="0,0,0,18"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel Margin="0,0,18,0"><TextBlock Text="{Binding [History.Title], Source={StaticResource LocalizedStrings}}" FontSize="25" FontWeight="Bold" /><TextBlock Text="{Binding [History.Subtitle], Source={StaticResource LocalizedStrings}}" Margin="0,6,0,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="13" TextWrapping="Wrap" /></StackPanel><Button Grid.Column="1" Content="{Binding [History.OpenLogs], Source={StaticResource LocalizedStrings}}" HorizontalAlignment="Right" Style="{StaticResource SecondaryButtonStyle}" Height="38" Click="OpenLogs_Click" /></Grid>
                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="18">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Grid Margin="0,0,0,14"><TextBlock Text="{Binding [History.LocalRuns], Source={StaticResource LocalizedStrings}}" FontSize="15" FontWeight="SemiBold" /><TextBlock Text="{Binding [History.NoTelemetry], Source={StaticResource LocalizedStrings}}" HorizontalAlignment="Right" Foreground="{DynamicResource GreenBrush}" FontSize="10" FontWeight="Bold" /></Grid>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"><ItemsControl ItemsSource="{Binding HistoryItems}" ItemTemplate="{StaticResource HistoryTemplate}" /></ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Settings -->
                    <ScrollViewer x:Name="SettingsPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="{Binding [Settings.Title], Source={StaticResource LocalizedStrings}}" FontSize="25" FontWeight="Bold" />
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,13">
                                <StackPanel>
                                    <TextBlock Text="{Binding [Settings.General.Title], Source={StaticResource LocalizedStrings}}" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding [Settings.Language.Title], Source={StaticResource LocalizedStrings}}" Margin="0,15,0,0" FontSize="12.5" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding [Settings.Language.Description], Source={StaticResource LocalizedStrings}}" Margin="0,4,0,11" Foreground="{DynamicResource TextSubtleBrush}" FontSize="10.5" TextWrapping="Wrap" />
                                    <ComboBox x:Name="LanguageSelector" Style="{StaticResource SettingsComboBoxStyle}" SelectionChanged="LanguageSelector_SelectionChanged">
                                        <ComboBoxItem Tag="pt-BR" Content="{Binding [Settings.Language.PortugueseBrazil], Source={StaticResource LocalizedStrings}}" />
                                        <ComboBoxItem Tag="en" Content="{Binding [Settings.Language.English], Source={StaticResource LocalizedStrings}}" />
                                    </ComboBox>
                                    <Separator Margin="0,13" Background="{DynamicResource BorderSoftBrush}" />
                                    <TextBlock Text="{Binding [Settings.Appearance.Title], Source={StaticResource LocalizedStrings}}" Margin="0,0,0,4" FontSize="12.5" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding [Settings.Appearance.Description], Source={StaticResource LocalizedStrings}}" Margin="0,0,0,11" Foreground="{DynamicResource TextSubtleBrush}" FontSize="10.5" TextWrapping="Wrap" />
                                    <ComboBox x:Name="ThemeSelector" Style="{StaticResource SettingsComboBoxStyle}" SelectionChanged="ThemeSelector_SelectionChanged">
                                        <ComboBoxItem Tag="system" Content="{Binding [Settings.Appearance.System], Source={StaticResource LocalizedStrings}}" />
                                        <ComboBoxItem Tag="dark" Content="{Binding [Settings.Appearance.Dark], Source={StaticResource LocalizedStrings}}" />
                                        <ComboBoxItem Tag="light" Content="{Binding [Settings.Appearance.Light], Source={StaticResource LocalizedStrings}}" />
                                    </ComboBox>
                                    <Separator Margin="0,13" Background="{DynamicResource BorderSoftBrush}" />
                                    <CheckBox Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding MinimizeToTrayOnClose}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding [Settings.CloseBehavior.Title], Source={StaticResource LocalizedStrings}}" FontSize="12.5" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding [Settings.CloseBehavior.Description], Source={StaticResource LocalizedStrings}}" Margin="0,3,0,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="10.5" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </CheckBox>
                                    <Separator Margin="0,13" Background="{DynamicResource BorderSoftBrush}" />
                                    <CheckBox Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding LaunchAtStartup}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding [Settings.StartWithWindows.Title], Source={StaticResource LocalizedStrings}}" FontSize="12.5" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding [Settings.StartWithWindows.Description], Source={StaticResource LocalizedStrings}}" Margin="0,3,0,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="10.5" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </CheckBox>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <Border Grid.Row="2"
                    Padding="16,8"
                    Background="{DynamicResource ChromeBrush}"
                    BorderBrush="{DynamicResource BorderSoftBrush}"
                    BorderThickness="0,1,0,0">
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource LinkButtonStyle}"
                            Padding="4,2"
                            Click="ReportBug_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource OrangeLightBrush}" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding [BugReport.Link], Source={StaticResource LocalizedStrings}}" FontSize="10.5" TextDecorations="Underline" Foreground="{DynamicResource TextMutedBrush}" />
                        </StackPanel>
                    </Button>
                    <Rectangle Width="1" Height="14" Margin="12,0" Fill="{DynamicResource BorderSoftBrush}" />
                    <TextBlock Text="{Binding [Brand.FooterCopyright], Source={StaticResource LocalizedStrings}}" Foreground="{DynamicResource TextSubtleBrush}" FontSize="8.5" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
