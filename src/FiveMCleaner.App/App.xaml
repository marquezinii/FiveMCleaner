<Application x:Class="FiveMCleaner.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:FiveMCleaner.App.Services"
             xmlns:local="clr-namespace:FiveMCleaner.App"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Palette.xaml" />
                <ResourceDictionary Source="Themes/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <local:BrushKeyConverter x:Key="BrushKeyConverter" />
            <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
            <services:LocalizedStrings x:Key="LocalizedStrings" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
