<Window x:Class="FiveMCleaner.App.Views.OptimizationConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="FiveMCleaner"
        Icon="/FiveMCleaner;component/Assets/FiveMCleaner.png"
        Width="470"
        Height="265"
        MinWidth="420"
        MinHeight="245"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{DynamicResource BackgroundBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="7" CornerRadius="0" GlassFrameThickness="0" />
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource StrongBorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="58" />
                <RowDefinition Height="*" />
                <RowDefinition Height="70" />
            </Grid.RowDefinitions>

            <Border Background="{DynamicResource ChromeBrush}"
                    BorderBrush="{DynamicResource BorderSoftBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0">
                <Grid Margin="18,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32" CornerRadius="9" Background="#24FF7A18">
                            <TextBlock Text="&#xE7BA;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Foreground="{DynamicResource OrangeLightBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding TitleText}"
                                   Margin="11,0,0,0"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Button HorizontalAlignment="Right"
                            Style="{StaticResource WindowButtonStyle}"
                            ToolTip="{Binding [Window.Close], Source={StaticResource LocalizedStrings}}"
                            Click="Dismiss_Click">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="24,21,24,12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="38" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <Border Width="32" Height="32" CornerRadius="9" Background="#1837C889" VerticalAlignment="Top">
                    <TextBlock Text="&#xE7BA;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               Foreground="{DynamicResource OrangeLightBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <TextBlock Grid.Column="1"
                           Text="{Binding MessageText}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="12"
                           LineHeight="18"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </Grid>

            <Border Grid.Row="2"
                    Background="{DynamicResource ChromeBrush}"
                    BorderBrush="{DynamicResource BorderSoftBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="18,0">
                    <Button Content="{Binding KeepWorkingText}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="38"
                            Padding="16,0"
                            Margin="0,0,9,0"
                            IsCancel="True"
                            Click="Dismiss_Click" />
                    <Button Content="{Binding ConfirmText}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="38"
                            Padding="17,0"
                            IsDefault="True"
                            Click="Confirm_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
