<Project>
  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Deterministic>true</Deterministic>
    <ContinuousIntegrationBuild Condition="'$(CI)' == 'true'">true</ContinuousIntegrationBuild>
    <Authors>Felipe Marquezini</Authors>
    <Company>Felipe Marquezini</Company>
    <Copyright>Copyright (c) 2026 Felipe Marquezini. All rights reserved.</Copyright>
    <RepositoryType>git</RepositoryType>
    <RepositoryUrl>https://github.com/marquezinii/FiveMCleaner</RepositoryUrl>
    <Product>FiveMCleaner</Product>
    <Version>0.2.0</Version>
  </PropertyGroup>
</Project>
